# Copia este archivo a .env y rellena los valores. NUNCA commitees .env (está en .gitignore).
# Recomendado: NO pongas PRIVATE_KEY aquí; usa `cast wallet import frontle-deployer`
# y despliega con --account frontle-deployer (la clave queda cifrada, no en texto plano).

# --- RPCs (ya verificados contra la doc de Celo) ---
CELO_SEPOLIA_RPC=https://forno.celo-sepolia.celo-testnet.org
CELO_RPC=https://forno.celo.org

# --- Verificación en Celoscan (https://celoscan.io -> API Keys) ---
CELOSCAN_API_KEY=

# --- Parámetros del despliegue (Deploy.s.sol) ---
# Wallet del backend que cierra los días con rollDay (onlyOperator). OBLIGATORIA.
# Para probar en Sepolia puedes usar tu propia dirección de deployer.
OPERATOR=0x...

# Stablecoin. DÉJALO VACÍO en Sepolia (el script despliega un MockERC20).
# En Mainnet, ponlo a USDm: 0x765DE816845861e75A25fCA122bb6898B8B1282a
# TOKEN_ADDRESS=

# Fees en unidades mínimas del token (18 decimales para USDm). Opcionales.
# Por defecto: reintento 0.10, protocolo 20% (2000 bps), pistas 0.05/0.05/0.10.
# ATTEMPT_FEE=100000000000000000
# PROTOCOL_BPS=2000
# Precios de pista por tipo (0=inicial, 1=siguiente silueta, 2=todas):
# HINT_FEE_INITIAL=50000000000000000
# HINT_FEE_NEXT=50000000000000000
# HINT_FEE_ALL=100000000000000000

# Solo si decides usar clave en texto plano en vez de cast wallet (no recomendado):
# PRIVATE_KEY=0x...
